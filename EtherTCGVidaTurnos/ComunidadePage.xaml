<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EtherTCGVidaTurnos.ComunidadePage"
             BackgroundColor="LightGray"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20" RowSpacing="20">

        <!-- Cabeçalho -->
        <VerticalStackLayout Grid.Row="0" Spacing="10" HorizontalOptions="Center">
            <Image Source="logo.png"
                   HeightRequest="120"
                   Aspect="AspectFit" />
            <Label Text="Comunidade"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="Black"
                   HorizontalOptions="Center" />
            <Label Text="Fique ligado nos criadores de conteúdo."
                   FontSize="18"
                   TextColor="Black"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Corpo: lista de criadores -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout x:Name="ListaCriadores" Spacing="15" />
        </ScrollView>

        <!-- Rodapé -->
        <VerticalStackLayout Grid.Row="2" Spacing="4">
            <Button Text="Voltar"
                    FontSize="18"
                    Clicked="OnVoltarClicked"
                    FontAttributes="Bold"
                    BackgroundColor="#FFDC91"
                    TextColor="Black"
                    CornerRadius="30" />
            <Label Text="© Éther Card Game"
                   FontSize="14"
                   TextColor="Black"
                   HorizontalOptions="Center" />
            <Label Text="Este é um projeto feito de fãs para fãs, não oficial."
                   FontSize="12"
                   TextColor="Black"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>

    </Grid>
</ContentPage>
